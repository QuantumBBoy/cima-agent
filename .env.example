# Modelo LLM usado por los nodos de triaje / verificación / redacción.
# Formato "provider:model" entendido por langchain.init_chat_model.
PHARMA_AGENT_MODEL=anthropic:claude-sonnet-4-5

# Credencial del proveedor elegido (Anthropic por defecto).
ANTHROPIC_API_KEY=sk-ant-...

# --- Alternativa: Ollama Cloud (endpoint OpenAI-compatible) ---------------
# Instala el extra:  uv sync --extra ollama   (o pip install -e ".[ollama]")
# Los modelos open de Ollama Cloud NO respetan el structured output nativo, así
# que el agente fuerza JSON por prompt + parseo tolerante (ver src/.../llm.py).
# PHARMA_AGENT_MODEL=ollama:gpt-oss:20b
# OLLAMA_API_KEY=...
# OLLAMA_BASE_URL=https://ollama.com/v1   # opcional, este es el valor por defecto

# Comando para lanzar el servidor MCP mcp-aemps por stdio.
# Por defecto: "uvx mcp-aemps@latest stdio". Cambia solo si lo tienes instalado de otra forma.
# MCP_AEMPS_COMMAND=uvx
# MCP_AEMPS_ARGS=mcp-aemps@latest stdio
